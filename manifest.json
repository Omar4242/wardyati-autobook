{
  "manifest_version": 3,
  "name": "Wardyati Auto-Book",
  "version": "1.0",
  "description": "Auto-books your selected shift on Wardyati the instant coordination opens",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": ["https://wardyati.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://wardyati.com/rooms/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
